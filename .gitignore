# MATLAB generated files
*.asv
*.m~
*.mex*
*.mlappinstall
*.mlpkginstall

# MATLAB output/temp
slprj/
codegen/
*.slxc

# Generated outputs (reproducible from code)
figures/
building_geometry.json

# Screenshots (regenerable from MATLAB/ParaView/Python)
screenshots/
!screenshots/reference_photos/

# OpenFOAM runtime output (large, regenerable)
# Note: citicorp_cfd/0/ is NOT ignored — it contains initial/boundary conditions
citicorp_cfd/[1-9]*/
citicorp_cfd/constant/polyMesh/
citicorp_cfd/constant/triSurface/*.eMesh
citicorp_cfd/constant/triSurface/*.obj
citicorp_cfd/constant/extendedFeatureEdgeMesh/
citicorp_cfd/processor*/
citicorp_cfd/postProcessing/
citicorp_cfd/log.*
citicorp_cfd/*.foam

# OpenFOAM intermediate/generated files
citicorp_cfd/0/phi
citicorp_cfd/0/polyMesh/
citicorp_cfd/badFaces
citicorp_cfd/problemFaces
citicorp_cfd/surroundings_*.obj
citicorp_cfd/surroundings_osm.stl
citicorp_cfd/citicorp_tower.stl
citicorp_cfd/citicorp_stilts.stl
citicorp_cfd/topo_grid.csv
citicorp_cfd/_stl_data.js
citicorp_cfd/.claude/

# STL binary duplicates and alternative geometry (regenerable)
citicorp_cfd/constant/triSurface/*_bin.stl
citicorp_cfd/constant/triSurface/*_lod2*.stl
citicorp_cfd/constant/triSurface/*_nyc3d.stl
citicorp_cfd/constant/triSurface/zone_*.vtk

# Cached query results (regenerable)
citicorp_cfd/_socrata_buildings.json
citicorp_cfd/_citygml_bins.json
citicorp_cfd/citicorp_footprint.json

# Credentials (NEVER commit)
**/gee-key.json

# Downloaded data (large, regenerable)
citicorp_cfd/_citygml/

# OS files
Thumbs.db
.DS_Store
desktop.ini
nul
_ul
_ul-*

# IDE
.vscode/
*.swp
*.swo
